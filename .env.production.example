# ════════════════════════════════════════════════════════════════════
# Rusto LMS — Production Environment Variables
# Copy this file to .env.production on your EC2 server
# NEVER commit .env.production to git
# ════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_THIS_strong_password_here
POSTGRES_DB=rusto_lms
DATABASE_URL=postgresql://lms:CHANGE_THIS_strong_password_here@db:5432/rusto_lms

# ── Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_generate_with_openssl_rand_hex_32
JWT_EXPIRE_HOURS=8

# ── Admin Account ────────────────────────────────────────────────────
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=CHANGE_THIS_strong_password_here

# ── CORS (comma-separated domains) ───────────────────────────────────
# Add all domains that serve the frontend
CORS_ORIGINS=https://pms.yourdomain.com,https://book.yourdomain.com,https://yourdomain.com

# ── Razorpay (online payments) ────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── SMS Provider ─────────────────────────────────────────────────────
# Choose ONE: twilio (global) or msg91 (India)

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# MSG91 (India) — https://control.msg91.com → Security → Auth Key
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=RUSTO1

# ── Email (SMTP) ──────────────────────────────────────────────────────
# Works with Gmail, Sendgrid, AWS SES, any SMTP provider

# Gmail example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_app_password_from_google

# AWS SES example:
# SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=AKIAIOSFODNN7EXAMPLE
# SMTP_PASSWORD=your_ses_smtp_password

SMTP_FROM_EMAIL=no-reply@yourdomain.com
SMTP_FROM_NAME=Rusto LMS

# ── AI Assistant (Anthropic Claude) ───────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# Optional OpenAI fallback
OPENAI_API_KEY=sk-xxxxxxxxxx

# AI provider routing: auto | anthropic | openai | heuristic
AGENT_PROVIDER=auto

# ── Frontend API URL ─────────────────────────────────────────────────
# Where the frontend sends API requests (proxied by nginx in production)
VITE_API_URL=/api

# ── Server ───────────────────────────────────────────────────────────
TZ=Asia/Kolkata
