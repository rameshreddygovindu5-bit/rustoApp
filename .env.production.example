# ════════════════════════════════════════════════════════════════════
#  Production environment template
#  Copy to .env.production on the EC2 host and fill in REAL values.
#  DO NOT commit the real .env.production — it contains secrets.
#  (The ec2-bootstrap.sh script auto-generates a secure version.)
# ════════════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────────────
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME_TO_LONG_RANDOM_STRING
POSTGRES_DB=lodge_lms
DATABASE_URL=postgresql://lms:CHANGE_ME_TO_LONG_RANDOM_STRING@db:5432/lodge_lms

# ─── Application secrets ────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_SECRET_KEY=CHANGE_ME_TO_64_PLUS_HEX_CHARS

# First-boot admin (created if no users exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@1234

# ─── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# When the frontend is served by the same nginx as the backend (the
# default setup), put your public domain(s) here.
CORS_ORIGINS=http://localhost,https://your-domain.example.com

# ─── Frontend build ─────────────────────────────────────────────────
# Path the React app calls to reach the API (nginx proxies /api → backend)
VITE_API_URL=/api

# ─── AI Agent (optional) ────────────────────────────────────────────
# Set ONE for full natural-language agent. Without keys the agent runs
# in basic mode (slash commands + simple intent matching).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# AGENT_PROVIDER=auto

# ─── Misc ───────────────────────────────────────────────────────────
TZ=Asia/Kolkata
