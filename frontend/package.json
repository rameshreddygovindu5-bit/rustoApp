{
  "name": "lodge-lms-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite --port 3000",
    "dev:pms": "vite --config vite.config.pms.js --port 3001",
    "build:pms": "vite build --config vite.config.pms.js",
    "preview:pms": "vite preview --config vite.config.pms.js --port 4001",
    "dev:customer": "vite --config vite.config.customer.js --port 3002",
    "build:customer": "vite build --config vite.config.customer.js",
    "preview:customer": "vite preview --config vite.config.customer.js --port 4002",
    "build:all": "npm run build:pms && npm run build:customer",
    "dev:all": "concurrently --kill-others-on-fail -n \"PMS,CUSTOMER,COMBINED\" -c \"yellow,green,blue\" \"npm run dev:pms\" \"npm run dev:customer\" \"npm run dev\"",
    "dev:all:named": "concurrently --kill-others -n \"COMBINED,PMS,CUSTOMER\" -c \"blue,yellow,green\" \"npm:dev\" \"npm:dev:pms\" \"npm:dev:customer\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "date-fns": "^3.3.1",
    "lucide-react": "^0.330.0",
    "react": "^18.2.0",
    "react-datepicker": "^6.1.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.22.0",
    "react-toastify": "^10.0.4",
    "recharts": "^2.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.55",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.17",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "vitest": "^4.1.9",
    "concurrently": "^9.0.0"
  }
}