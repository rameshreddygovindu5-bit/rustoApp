# ──────────────────────────────────────────────────────────────────
#  Rusto — Local development env vars
#  Copy this file to .env (gitignored) and edit if needed.
#  Defaults work out-of-the-box with the bundled SQLite DB.
# ──────────────────────────────────────────────────────────────────

# Database
# ────────
# Default: SQLite file in backend/ directory. Zero setup, ships with
# pre-seeded demo data. Recommended for local dev.
DATABASE_URL=sqlite:///./lodge_lms.db

# For Postgres locally (requires `docker compose up postgres` or own install):
#   DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/rusto_lms

# Auth — change in production
# ───────────────────────────
JWT_SECRET_KEY=dev-secret-change-me-for-production-only
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Application
APP_ENV=development
DEBUG=true
# Vite dev server is 3000 by default (vite.config.js); 5173 is Vite's
# original default in case someone overrides the port.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Default credentials (seeded ONLY when DB is empty on first boot)
# ────────────────────────────────────────────────────────────────
# Login at http://localhost:3000/login with:
#   - admin       / Admin@1234          (lodge admin for default lodge 1)
#   - superadmin  / superadmin123        (cross-tenant operator)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@1234

# ── Optional integrations ──
# Set these only if you want to test the live integrations.
# Leave blank to use the built-in mock providers (work end-to-end).

# SMTP configuration is stored PER LODGE in the settings table
# (Settings → Email in the UI). For SYSTEM emails sent by Rusto
# to lodge owners (welcome credentials, invoice PDFs, renewal reminders,
# refund confirmations), the platform uses lodge 1's SMTP config as
# the "system" sender via an automatic fallback. To enable these,
# log in as `admin` and configure SMTP in Settings → Email.

# AI agent — without keys, runs in basic pattern-matching mode
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Razorpay sandbox — without keys, customer checkout runs in mock mode
# (accepts "mock_signature" so the booking flow can be tested end-to-end)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxx

# WhatsApp Business — without these, sends are logged to DB but not actually delivered
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=rusto-wa-verify
# WHATSAPP_FORCE_MOCK=1     # force mock provider even when credentials are set
