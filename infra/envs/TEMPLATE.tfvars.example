# ════════════════════════════════════════════════════════════════════
#  Template for deploying to a NEW target (any AWS account).
#
#  Copy this to envs/<target-name>.tfvars (e.g. envs/dev.tfvars,
#  envs/client-a.tfvars) and adjust. Then run the pipeline with:
#     source = infra (then database, then code, or 'all')
#     environment = <target-name>
#     aws_account_id = <the account to deploy into>
#
#  Nothing here is account-specific — the SAME source deploys to ANY
#  account; only these values + the account ID differ per target.
# ════════════════════════════════════════════════════════════════════

aws_region  = "us-east-1"
environment = "REPLACE_ME"   # must match the file name and the pipeline input

vpc_cidr      = "10.40.0.0/16"   # use a unique CIDR per target if you peer them
instance_type = "t3.small"

db_instance_class        = "db.t4g.micro"
db_allocated_storage     = 20
db_engine_version        = "16.4"
db_name                  = "rusto_lms"
db_username              = "lms_admin"
db_backup_retention_days = 7

# Set true for any target holding real data (multi-AZ, deletion protection,
# final snapshot on destroy). false is fine for throwaway dev/demo targets.
production_grade = false

# Lock this to your IP for real use, e.g. "203.0.113.4/32".
admin_ingress_cidr = "0.0.0.0/0"

cors_origins = "https://REPLACE_ME.your-domain.example.com"
