# ─────────────────────────────────────────────────────────
#  Udumula's Grand LMS — Backend Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL=postgresql://lms_user:lms_password@localhost:5432/udumulas_lms

# JWT Security
SECRET_KEY=change-this-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# File Uploads
UPLOAD_DIR=./uploads

# Environment
ENVIRONMENT=development
