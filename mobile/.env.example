# ─── Rusto Mobile — API Configuration ────────────────────────────────────────
#
# Copy this file to `.env` (it is gitignored) and set the URL to where
# your Rusto backend is running.
#
# IMPORTANT for Expo Go on a physical device (iPhone / Android):
#   Your phone CANNOT reach `localhost` or `127.0.0.1` — those refer to
#   the phone itself, not your development machine.
#   You must use your machine's LAN IP address instead.
#
# How to find your LAN IP:
#   macOS:    ipconfig getifaddr en0
#   Linux:    hostname -I | awk '{print $1}'
#   Windows:  ipconfig | findstr "IPv4"
#
# How to start Expo with the correct URL:
#   EXPO_PUBLIC_API_URL=http://192.168.1.xxx:8000 npx expo start
#
#   Or set this in .env and just run: npx expo start

EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
