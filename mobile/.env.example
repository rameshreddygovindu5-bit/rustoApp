# Copy to `.env` (gitignored) and set the URL to where your Rusto backend runs.
# Use your machine's LAN IP, not localhost — the device on your phone
# can't reach 127.0.0.1 of your dev machine.
# Find your LAN IP:
#   macOS:    ipconfig getifaddr en0
#   Linux:    hostname -I | awk '{print $1}'
#   Windows:  ipconfig | findstr IPv4
EXPO_PUBLIC_API_URL=http://192.168.1.10:8000
