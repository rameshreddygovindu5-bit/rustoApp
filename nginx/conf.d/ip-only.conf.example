# ════════════════════════════════════════════════════════════════════
# Rusto LMS — IP-only nginx config (no domain name needed)
#
# Use this when you DON'T have a domain yet.
# Staff access PMS at:     http://YOUR_IP:3001  (or /pms path)
# Guests access booking at: http://YOUR_IP       (or :3002)
#
# To use: copy this to default.conf and run docker compose up
# ════════════════════════════════════════════════════════════════════

upstream rusto_backend     { server backend:8000;         keepalive 32; }
upstream rusto_pms         { server frontend_pms:80;      keepalive 16; }
upstream rusto_customer    { server frontend_customer:80; keepalive 16; }

limit_req_zone $binary_remote_addr zone=api_limit:10m   rate=60r/m;
limit_req_zone $binary_remote_addr zone=login_limit:10m rate=10r/m;

# ── Main server — port 80 ─────────────────────────────────────────────
server {
    listen 80 default_server;
    server_name _;

    client_max_body_size 25M;
    gzip on; gzip_vary on; gzip_min_length 1024;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;

    # ── Health check ──────────────────────────────────────────────────
    location = /health {
        proxy_pass http://rusto_backend/api/health;
        access_log off;
    }

    # ── API ───────────────────────────────────────────────────────────
    location /api/ {
        limit_req zone=api_limit burst=20 nodelay;
        proxy_pass         http://rusto_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        "";
        proxy_read_timeout 300s;
    }

    location /api/auth/login {
        limit_req zone=login_limit burst=5 nodelay;
        proxy_pass         http://rusto_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    }

    # ── Uploaded files ────────────────────────────────────────────────
    location /uploads/ {
        alias /var/www/uploads/;
        expires 7d;
    }

    # ── PMS staff portal at /pms path ─────────────────────────────────
    # Staff access: http://YOUR_IP/pms
    location /pms {
        proxy_pass         http://rusto_pms/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    }

    # ── Customer portal at / (default) ────────────────────────────────
    # Guests access: http://YOUR_IP
    location / {
        proxy_pass         http://rusto_customer;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    }
}

# ── PMS on dedicated port 3001 (alternative access) ──────────────────
# Staff can also use: http://YOUR_IP:3001
server {
    listen 3001;
    server_name _;

    location /api/ {
        proxy_pass         http://rusto_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_read_timeout 300s;
    }

    location /uploads/ {
        alias /var/www/uploads/;
        expires 7d;
    }

    location / {
        proxy_pass         http://rusto_pms;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
    }
}

# ── Customer portal on dedicated port 3002 ────────────────────────────
# Guests can also use: http://YOUR_IP:3002
server {
    listen 3002;
    server_name _;

    location /api/ {
        proxy_pass         http://rusto_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_read_timeout 300s;
    }

    location / {
        proxy_pass         http://rusto_customer;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
    }
}
